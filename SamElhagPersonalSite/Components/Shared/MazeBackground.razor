@inject IJSRuntime JS

<canvas id="bg"></canvas>

<style>
    #bg {
        display: block;
        position: fixed;
        top: 0;
        left: 0;
        z-index: -1;
        pointer-events: none;
        width: 100%;
        height: 100%;
        background: #080c18;
    }
</style>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initMazeBackground");
        }
    }
}
