@* Optimized Image Component with Lazy Loading *@

<img src="@Src" 
     alt="@Alt" 
     loading="lazy" 
     decoding="async"
     class="@Class"
     style="@Style" />

@code {
    [Parameter] public string Src { get; set; } = "";
    [Parameter] public string Alt { get; set; } = "";
    [Parameter] public string Class { get; set; } = "";
    [Parameter] public string Style { get; set; } = "";
}
