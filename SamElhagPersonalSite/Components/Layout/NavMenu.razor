@using MudBlazor

<MudHidden Breakpoint="Breakpoint.MdAndUp">
    <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.End" OnClick="@ToggleDrawer" />
</MudHidden>

<MudHidden Breakpoint="Breakpoint.SmAndDown">
    <MudStack Row="true" Spacing="1">
        <MudButton Href="/" Variant="Variant.Text" Color="Color.Inherit" Style="font-family: 'Inter', sans-serif; text-transform: none; font-weight: 500; color: #E8F0FF;">Home</MudButton>
        <MudButton Href="/projects" Variant="Variant.Text" Color="Color.Inherit" Style="font-family: 'Inter', sans-serif; text-transform: none; font-weight: 500; color: #E8F0FF;">Projects</MudButton>
        <MudButton Href="/about" Variant="Variant.Text" Color="Color.Inherit" Style="font-family: 'Inter', sans-serif; text-transform: none; font-weight: 500; color: #E8F0FF;">About</MudButton>
        <#E8F0FF; Href="/skillsAndInterests" Variant="Variant.Text" Color="Color.Inherit" Style="font-family: 'Inter', sans-serif; text-transform: none; font-weight: 500; color: #E8F0FF;">Skills and Interests</MudButton>
        <MudButton Href="/contact" Variant="Variant.Text" Color="Color.Inherit" Style="font-family: 'Inter', sans-serif; text-transform: none; font-weight: 500; color: #E8F0FF;">Contact</MudButton>
    </MudStack>
</MudHidden>

@code {
    [CascadingParameter]
    public required Action ToggleDrawer { get; set; }
}

