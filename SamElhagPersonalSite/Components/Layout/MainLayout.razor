@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="false" Style="background: rgba(10, 15, 30, 0.95); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(91, 141, 239, 0.2);">
        <MudText Typo="Typo.h6" Class="text-gradient-brand ml-3">
            [Sam Elhag] / [Sam.E]
        </MudText>
        <MudSpacer />
        <MudStack Row="true" Spacing="1" Class="mr-3">
            <MudButton Href="/" Color="Color.Inherit" Variant="Variant.Text" Class="nav-link-custom">Home</MudButton>
            <MudButton Href="/about" Color="Color.Inherit" Variant="Variant.Text" Class="nav-link-custom">About</MudButton>
            <MudButton Href="/Interests" Color="Color.Inherit" Variant="Variant.Text" Class="nav-link-custom">Interests</MudButton>
            <MudButton Href="/projects" Color="Color.Inherit" Variant="Variant.Text" Class="nav-link-custom">Projects</MudButton>
            <MudButton Href="/contact" Variant="Variant.Filled" Class="nav-link-custom"
                      Style="background: linear-gradient(135deg, #5B8DEF 0%, #7CB8FF 100%); color: white; font-weight: 600; border-radius: 8px; box-shadow: 0 4px 20px rgba(91, 141, 239, 0.5);">
                Contact
            </MudButton>
        </MudStack>
    </MudAppBar>
    <MudMainContent Style="
        background-color: transparent;
        min-height: 100vh;
        position: relative;
    ">
        <div style="position: relative; z-index: 1;">
        <div>
            @Body
        </div>

        <!-- Footer -->
        <MudPaper Square="true" Elevation="0" Class="pa-8 mt-12" Style="background: rgba(10, 10, 20, 0.6); backdrop-filter: blur(10px); border-top: 1px solid rgba(192, 192, 192, 0.15);">
            <MudContainer MaxWidth="MaxWidth.Large">
                <MudGrid Spacing="6">
                    <MudItem xs="12" md="5">
                        <MudText Typo="Typo.h4" Class="text-gradient-brand" Style="margin-bottom: 16px;">
                             [Sam Elhag] / [Sam.E]
                        </MudText>
                        <MudText Typo="Typo.body1" Style="font-family: 'Inter', sans-serif; color: rgba(255,255,255,0.7); font-size: 1.05rem; line-height: 1.7; font-weight: 400;">
                            Always Learning, Always Building.
                        </MudText>
                        <MudStack Row="true" Spacing="3" Class="mt-6">
                            <MudIconButton Icon="@Icons.Custom.Brands.GitHub"
                                           Href="https://github.com/SamElhagDev"
                                           Target="_blank"
                                           Color="Color.Surface" Size="Size.Large"
                                           Class="footer-social-btn" />
                            <MudIconButton Icon="@Icons.Custom.Brands.LinkedIn"
                                           Href="https://www.linkedin.com/in/sam-elhag-b82312102/"
                                           Target="_blank"
                                           Color="Color.Surface" Size="Size.Large"
                                           Class="footer-social-btn" />
                            <MudIconButton Icon="@Icons.Custom.Brands.Twitter"
                                           Href="https://x.com/SamEElhag"
                                           Target="_blank"
                                           Color="Color.Surface" Size="Size.Large"
                                           Class="footer-social-btn" />                       
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudText Typo="Typo.h6" Class="footer-heading">Quick Links</MudText>
                        <MudStack Spacing="3">
                            <MudLink Href="/" Class="footer-link">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                                    <span>Home</span>
                                </MudStack>
                            </MudLink>
                            <MudLink Href="/about" Class="footer-link">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                                    <span>About</span>
                                </MudStack>
                            </MudLink>
                            <MudLink Href="/Interests" Class="footer-link">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                                    <span>Interests</span>
                                </MudStack>
                            </MudLink>
                            <MudLink Href="/projects" Class="footer-link">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                                    <span>Projects</span>
                                </MudStack>
                            </MudLink>
                            <MudLink Href="/contact" Class="footer-link">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                                    <span>Contact</span>
                                </MudStack>
                            </MudLink>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.h6" Class="footer-heading">Get In Touch</MudText>
                        <MudStack Spacing="3">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
                                <MudIcon Icon="@Icons.Material.Filled.Email" Style="color: rgba(255,255,255,0.9);" Size="Size.Medium" />
                                <div>
                                    <MudText Typo="Typo.body2" Class="text-muted-50" Style="font-size: 0.9rem;">Email</MudText>
                                    <MudText Typo="Typo.body1" Class="text-white-90" Style="font-size: 1.1rem;">sami.eltaj.elhag@gmail.com</MudText>
                                </div>
                            </MudStack>
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Style="color: rgba(255,255,255,0.9);" Size="Size.Medium" />
                                <div>
                                    <MudText Typo="Typo.body2" Class="text-muted-50" Style="font-size: 0.9rem;">Location</MudText>
                                    <MudText Typo="Typo.body1" Class="text-white-90" Style="font-size: 1.1rem;">Pittsburgh,PA</MudText>
                                </div>
                            </MudStack>
                        </MudStack>
                    </MudItem>
                </MudGrid>
                <MudDivider Class="my-8" Style="background: rgba(192, 192, 192, 0.2);" />
                <MudText Typo="Typo.body1" Align="Align.Center" Style="font-family: 'Inter', sans-serif; color: rgba(255,255,255,0.5); font-size: 0.95rem; font-weight: 400;">
                    © @DateTime.Now.Year Sam Elhag. All rights reserved.
                </MudText>
            </MudContainer>
        </MudPaper>
        </div>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

