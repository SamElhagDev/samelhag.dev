@page "/about"
@using MudBlazor
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Who I Am - Sam Elhag</PageTitle>

<style>
    /* Syntax highlighting — VS Code Dark+ */
    .syn-kw      { color: #569CD6; }
    .syn-tp      { color: #4EC9B0; }
    .syn-prop    { color: #DCDCAA; }
    .syn-str     { color: #CE9178; }
    .syn-num     { color: #B5CEA8; }
    .syn-comment { color: #6A9955; }
    .syn-iface-d { color: #7CB8FF; }
    .syn-iface-a { color: #6FC9D7; }
    .syn-iface-e { color: #C0C0C0; }
    .syn-iface-p { color: #C0C0C0; }
    .syn-iface-g { color: #7CB8FF; }
    .syn-iface-m { color: #6FC9D7; }

    .wia-code-block {
        background: rgba(0, 0, 0, 0.25);
        border-radius: 8px;
        padding: 12px;
        margin: 0;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        line-height: 1.65;
        overflow-x: auto;
        white-space: pre;
    }

    .wia-inner-card {
        background: rgba(10, 16, 38, 0.7);
        border-radius: 12px;
        padding: 18px;
        min-width: 0;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .wia-inner-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.3);
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8" Style="max-width: 1800px;">

    <!-- Section header -->
    <MudText Typo="Typo.h2" Align="Align.Center" GutterBottom="true" Class="mb-4 text-heading-bold" Style="color: white;">
       Anatomy of a Sam.E
    </MudText>

    <!-- View toggle -->
    <div style="display: flex; justify-content: center; margin-bottom: 24px;">
        <MudButton Variant="Variant.Filled" Size="Size.Medium"
                   StartIcon="@(showModel ? Icons.Material.Filled.Description : Icons.Material.Filled.Code)"
                   Class="btn-outlined-blue"
                   Style="padding: 8px 24px;"
                   OnClick="@(() => showModel = !showModel)">
            @(showModel ? "Words" : "Model")
        </MudButton>
    </div>

    <!-- ═══ Sam.E outer container ═══ -->
    <MudPaper Elevation="0" Style="background: rgba(22, 33, 62, 0.8); backdrop-filter: blur(20px); border: 2px solid rgba(91, 141, 239, 0.4); border-radius: 20px; padding: 28px; box-shadow: 0 8px 32px rgba(91, 141, 239, 0.15);">

        <!-- Header row -->
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="3">
            <div class="icon-box icon-box--md icon-box--brand">
                <MudIcon Icon="@Icons.Material.Filled.Person" Style="color: white; font-size: 1.8rem;" />
            </div>
            <MudText Style="color: white; font-weight: 700; font-family: 'JetBrains Mono', monospace; font-size: 1.25rem;">Sam.E</MudText>
        </MudStack>

        @if (!showModel)
        {
            <!-- ═══ Words view ═══ -->
            <div class="wia-inner-card" style="border: 1px solid rgba(91, 141, 239, 0.25); padding: 28px; max-width: 900px; margin: 0 auto;">
                <MudText Class="mb-4" Style="color: rgba(255,255,255,0.7); font-size: 1.05rem; line-height: 1.85;">
                    I'm a Sudanese-American developer and mechanical engineer based in Pittsburgh. I got my start
                    taking things apart as a kid in Khartoum, and never really stopped — the subjects just got more
                    interesting. These days I build full-stack applications, data pipelines, and the occasional
                    simulation for fun.
                </MudText>

                <MudText Class="mb-4" Style="color: rgba(255,255,255,0.7); font-size: 1.05rem; line-height: 1.85;">
                    My background is a bit unconventional. I studied mechanical engineering, spent time doing policy
                    analysis, and eventually landed in software — where everything clicked. I like working at the
                    intersection of systems thinking and code: turning messy, real-world problems into clean
                    architectures and reliable software.
                </MudText>

                <MudText Class="mb-4" Style="color: rgba(255,255,255,0.7); font-size: 1.05rem; line-height: 1.85;">
                    Most of my work lives in the .NET ecosystem — C#, Blazor, ASP.NET — but I reach for Rust when
                    performance matters and TypeScript when the browser demands it. I care about clean architecture,
                    automation, and building things that actually get used.
                </MudText>

                <MudText Style="color: rgba(255,255,255,0.7); font-size: 1.05rem; line-height: 1.85;">
                    Outside of work you'll find me debating policy, gaming with friends, or listening to music through
                    a pair of open-backs that are probably too expensive. Click <strong style="color: #7CB8FF;">Model</strong>
                    above if you want the structured version.
                </MudText>
            </div>
        }
        else
        {

        <!-- ── Interface definitions comment ── -->
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; color: #6A9955; margin: 4px 0 14px 4px;">// ── Interfaces ──</div>

        <!-- ── 3x2 interface grid ── -->
        <div style="display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px;">

            <!-- IDeveloper -->
            <div class="wia-inner-card" style="border: 1px solid rgba(91, 141, 239, 0.25);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <div class="icon-box icon-box--blue">
                        <MudIcon Icon="@Icons.Material.Filled.Code" Style="color: white; font-size: 1.2rem;" />
                    </div>
                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 700; color: #7CB8FF;">IDeveloper</span>
                </MudStack>
                <pre class="wia-code-block"><span class="syn-kw">public interface</span> <span class="syn-iface-d">IDeveloper</span>
{
    <span class="syn-kw">bool</span> <span class="syn-prop">WritesCleanCode</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">FullStack</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">Automates</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string[]</span> <span class="syn-prop">Languages</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string[]</span> <span class="syn-prop">Frameworks</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string</span> <span class="syn-prop">PreferredPattern</span> { <span class="syn-kw">get</span>; }
}</pre>
            </div>

            <!-- IAnalyst -->
            <div class="wia-inner-card" style="border: 1px solid rgba(111, 201, 215, 0.25);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <div class="icon-box icon-box--cyan">
                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Style="color: white; font-size: 1.2rem;" />
                    </div>
                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 700; color: #6FC9D7;">IAnalyst</span>
                </MudStack>
                <pre class="wia-code-block"><span class="syn-kw">public interface</span> <span class="syn-iface-a">IAnalyst</span>
{
    <span class="syn-kw">bool</span> <span class="syn-prop">DataDriven</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">DetailOriented</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">FindsRootCause</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string[]</span> <span class="syn-prop">Tools</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string</span> <span class="syn-prop">Domain</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string</span> <span class="syn-prop">Approach</span> { <span class="syn-kw">get</span>; }
}</pre>
            </div>

            <!-- IMechanicalEngineer -->
            <div class="wia-inner-card" style="border: 1px solid rgba(139, 0, 0, 0.35);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <div class="icon-box icon-box--red">
                        <MudIcon Icon="@Icons.Material.Filled.Engineering" Style="color: white; font-size: 1.2rem;" />
                    </div>
                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 700; color: #C0C0C0;">IMechanicalEngineer</span>
                </MudStack>
                <pre class="wia-code-block"><span class="syn-kw">public interface</span> <span class="syn-iface-e">IMechanicalEngineer</span>
{
    <span class="syn-kw">bool</span> <span class="syn-prop">SystemsThinker</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">BuildsToSpec</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string</span> <span class="syn-prop">Degree</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string[]</span> <span class="syn-prop">Disciplines</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string[]</span> <span class="syn-prop">Software</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">PrecisionDriven</span> { <span class="syn-kw">get</span>; }
}</pre>
            </div>

            <!-- IPolicyWonk -->
            <div class="wia-inner-card" style="border: 1px solid rgba(192, 192, 192, 0.25);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <div class="icon-box icon-box--silver-red">
                        <MudIcon Icon="@Icons.Material.Filled.Gavel" Style="color: white; font-size: 1.2rem;" />
                    </div>
                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 700; color: #C0C0C0;">IPolicyWonk</span>
                </MudStack>
                <pre class="wia-code-block"><span class="syn-kw">public interface</span> <span class="syn-iface-p">IPolicyWonk</span>
{
    <span class="syn-kw">bool</span> <span class="syn-prop">StaysInformed</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">FollowsIncentives</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">DebateReady</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string[]</span> <span class="syn-prop">Topics</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string</span> <span class="syn-prop">Philosophy</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">BigPictureThinker</span> { <span class="syn-kw">get</span>; }
}</pre>
            </div>

            <!-- IGamer -->
            <div class="wia-inner-card" style="border: 1px solid rgba(91, 141, 239, 0.25);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <div class="icon-box icon-box--blue">
                        <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Style="color: white; font-size: 1.2rem;" />
                    </div>
                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 700; color: #7CB8FF;">IGamer</span>
                </MudStack>
                <pre class="wia-code-block"><span class="syn-kw">public interface</span> <span class="syn-iface-g">IGamer</span>
{
    <span class="syn-kw">bool</span> <span class="syn-prop">Competitive</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">Strategic</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">TeamPlayer</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">OneMoreRound</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string[]</span> <span class="syn-prop">Titles</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string</span> <span class="syn-prop">Platform</span> { <span class="syn-kw">get</span>; }
}</pre>
            </div>

            <!-- IAudiophile -->
            <div class="wia-inner-card" style="border: 1px solid rgba(111, 201, 215, 0.25);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <div class="icon-box icon-box--cyan">
                        <MudIcon Icon="@Icons.Material.Filled.Headphones" Style="color: white; font-size: 1.2rem;" />
                    </div>
                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 700; color: #6FC9D7;">IAudiophile</span>
                </MudStack>
                <pre class="wia-code-block"><span class="syn-kw">public interface</span> <span class="syn-iface-m">IAudiophile</span>
{
    <span class="syn-kw">bool</span> <span class="syn-prop">AlwaysListening</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">CuratesPlaylists</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">AppreciatesBass</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string[]</span> <span class="syn-prop">Genres</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">string</span> <span class="syn-prop">Setup</span> { <span class="syn-kw">get</span>; }
    <span class="syn-kw">bool</span> <span class="syn-prop">HeadphonesOn</span> { <span class="syn-kw">get</span>; }
}</pre>
            </div>

        </div>

        <!-- ── Implementation section ── -->
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; color: #6A9955; margin: 24px 0 6px 4px;">// ── Implementation ──</div>
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.88rem; line-height: 1.7; margin-bottom: 4px; white-space: pre-wrap; word-break: break-word;">
            <span class="syn-kw">public class</span> <span class="syn-tp">SamE</span> : <span class="syn-iface-d">IDeveloper</span>, <span class="syn-iface-a">IAnalyst</span>, <span class="syn-iface-e">IMechanicalEngineer</span>, <span class="syn-iface-p">IPolicyWonk</span>, <span class="syn-iface-g">IGamer</span>, <span class="syn-iface-m">IAudiophile</span>
        </div>
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.88rem; color: rgba(255,255,255,0.7); margin-bottom: 20px;">{</div>

        <!-- ── Sam.E own properties (centered top card) ── -->
        <div style="display: flex; justify-content: center; margin-bottom: 14px;">
            <div class="wia-inner-card" style="border: 1px solid rgba(78, 201, 176, 0.35); max-width: 480px; width: 100%;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <div class="icon-box icon-box--teal-blue">
                        <MudIcon Icon="@Icons.Material.Filled.Star" Style="color: white; font-size: 1.2rem;" />
                    </div>
                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 700; color: #4EC9B0;">SamE</span>
                </MudStack>
                <pre class="wia-code-block"><span class="syn-comment">// Core Properties</span>
<span class="syn-kw">public string</span> <span class="syn-prop">Name</span> => <span class="syn-str">"Sam Elhag"</span>;
<span class="syn-kw">public string</span> <span class="syn-prop">OnlineAlias</span> => <span class="syn-str">"Sam.E"</span>;
<span class="syn-kw">public int</span> <span class="syn-prop">YearsExperience</span> => <span class="syn-num">6</span>;
<span class="syn-kw">public bool</span> <span class="syn-prop">CaffeineRequired</span> => <span class="syn-kw">true</span>;
<span class="syn-kw">public string</span> <span class="syn-prop">CurrentLocation</span> => <span class="syn-str">"Pittsburgh, PA, USA"</span>;
<span class="syn-kw">public string</span> <span class="syn-prop">BirthLocation</span> => <span class="syn-str">"Khartoum, Sudan"</span>;
<span class="syn-kw">public string</span> <span class="syn-prop">Nationality</span> => <span class="syn-str">"American"</span>;</pre>
            </div>
        </div>

        <!-- ── 3x2 implementation grid ── -->
        <div style="display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px;">

            <!-- IDeveloper Implementation -->
            <div class="wia-inner-card" style="border: 1px solid rgba(91, 141, 239, 0.25);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <div class="icon-box icon-box--blue">
                        <MudIcon Icon="@Icons.Material.Filled.Code" Style="color: white; font-size: 1.2rem;" />
                    </div>
                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 700; color: #7CB8FF;">IDeveloper</span>
                </MudStack>
                <pre class="wia-code-block"><span class="syn-comment">// IDeveloper</span>
<span class="syn-prop">WritesCleanCode</span> => <span class="syn-kw">true</span>;
<span class="syn-prop">FullStack</span> => <span class="syn-kw">true</span>;
<span class="syn-prop">Automates</span> => <span class="syn-kw">true</span>;
<span class="syn-prop">Languages</span> => <span class="syn-kw">new</span>[] { <span class="syn-str">"C#"</span>, <span class="syn-str">"Rust"</span>, <span class="syn-str">"F#"</span>, <span class="syn-str">"TypeScript"</span> };
<span class="syn-prop">Frameworks</span> => <span class="syn-kw">new</span>[] { <span class="syn-str">".NET"</span>, <span class="syn-str">"Blazor"</span>, <span class="syn-str">"ASP.NET"</span>, <span class="syn-str">"Angular"</span> };
<span class="syn-prop">PreferredPattern</span> => <span class="syn-str">"Clean Architecture"</span>;</pre>
            </div>

            <!-- IAnalyst Implementation -->
            <div class="wia-inner-card" style="border: 1px solid rgba(111, 201, 215, 0.25);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <div class="icon-box icon-box--cyan">
