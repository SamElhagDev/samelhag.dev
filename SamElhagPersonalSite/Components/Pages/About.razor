<span class="syn-prop">Topics</span> => <span class="syn-kw">new</span>[] { <span class="syn-str">"Economics"</span>, <span class="syn-str">"Trade"</span>, <span class="syn-str">"Energy"</span>, <span class="syn-str">"Tech"</span> };
