<span class="syn-prop">BigPictureThinker</span> => <span class="syn-kw">true</span>;</pre>
            </div>

            <!-- IGamer Implementation -->
            <div class="wia-inner-card" style="border: 1px solid rgba(91, 141, 239, 0.25);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <div class="icon-box icon-box--blue">
