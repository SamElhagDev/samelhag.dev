<span class="syn-prop">Titles</span> => <span class="syn-kw">new</span>[] { <span class="syn-str">"Tarkov"</span>, <span class="syn-str">"CS2"</span>, <span class="syn-str">"Civ VI"</span> };
<span class="syn-prop">Platform</span> => <span class="syn-str">"PC"</span>;</pre>
