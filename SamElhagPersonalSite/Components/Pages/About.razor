<span class="syn-prop">Disciplines</span> => <span class="syn-kw">new</span>[] { <span class="syn-str">"Thermo"</span>, <span class="syn-str">"Fluids"</span>, <span class="syn-str">"Heat Transfer"</span> };
<span class="syn-prop">Software</span> => <span class="syn-kw">new</span>[] { <span class="syn-str">"SolidWorks"</span>, <span class="syn-str">"AutoCAD"</span>, <span class="syn-str">"MATLAB"</span> };
<span class="syn-prop">PrecisionDriven</span> => <span class="syn-kw">true</span>;</pre>
