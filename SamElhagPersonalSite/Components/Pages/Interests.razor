@page "/Interests"
@using MudBlazor
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<MudContainer>
    <!-- Media Section -->
    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true" Class="mb-4 text-white-bold">
        Interests
    </MudText>
    <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-10 text-muted-60" Style="font-weight: 400;">
