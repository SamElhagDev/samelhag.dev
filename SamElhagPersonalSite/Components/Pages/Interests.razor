                        <MudIcon Icon="@Icons.Material.Filled.LibraryMusic" Style="color: white; font-size: 1.8rem;" />
                    </div>
                    <MudText Typo="Typo.h5" Class="text-white-bold" Style="margin-left: 12px;">Music</MudText>
                </MudStack>
                <MudChipSet T="string">
                    <MudChip T="string" Class="chip-blue">C#</MudChip>
                    <MudChip T="string" Class="chip-blue">.NET Core</MudChip>
                    <MudChip T="string" Class="chip-blue">ASP.NET</MudChip>
                    <MudChip T="string" Class="chip-blue">Entity Framework</MudChip>
                    <MudChip T="string" Class="chip-blue">REST APIs</MudChip>
