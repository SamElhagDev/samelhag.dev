@page "/"
@using MudBlazor

<PageTitle>Sam Elhag - Software Developer</PageTitle>

<!-- Hero Section -->
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-16 mb-16">
    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" md="10" Class="text-center">
            <MudText Typo="Typo.h1" Class="mb-6" Style="font-weight: 800; font-size: 3.5rem; line-height: 1.2; color: rgba(255,255,255,0.95); text-shadow: 0 0 40px rgba(139, 0, 0, 0.3);">
                Hi, I'm Sam Elhag 🚀
            </MudText>
            <MudText Typo="Typo.h3" Class="mb-8" Style="background: linear-gradient(135deg, #7CB8FF 0%, #5B8DEF 50%, #6FC9D7 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 600;">
                Developer - Analyst - Engineer
            </MudText>
            <MudText Typo="Typo.h6" Class="mb-10" Style="color: rgba(255,255,255,0.65); font-weight: 400; line-height: 1.8; max-width: 800px; margin-left: auto; margin-right: auto;">
                I build modern web applications and cloud solutions that make a difference.
                Passionate about clean code, scalable architecture, and continuous learning.
            </MudText>
            <MudStack Row="true" Justify="Justify.Center" Spacing="4" Class="mb-4">
                <MudButton Variant="Variant.Filled" Size="Size.Large" Href="/projects" StartIcon="@Icons.Material.Filled.Work"
                          Style="background: linear-gradient(135deg, #5B8DEF 0%, #7CB8FF 100%); color: white; padding: 14px 36px; font-size: 1.05rem; font-weight: 600; border-radius: 10px; text-transform: none; box-shadow: 0 8px 32px rgba(91, 141, 239, 0.5); transition: all 0.3s;">
                    View My Work
                </MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Large" Href="/contact" StartIcon="@Icons.Material.Filled.Email"
                          Style="border: 2px solid rgba(91, 141, 239, 0.5); color: #E8F0FF; background: rgba(91, 141, 239, 0.1); backdrop-filter: blur(10px); padding: 14px 36px; font-size: 1.05rem; font-weight: 600; border-radius: 10px; text-transform: none; transition: all 0.3s;">
                    Get In Touch
                </MudButton>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudContainer>

<!-- Tech Stack Section -->
<MudPaper Elevation="0" Class="pa-12" Style="background: rgba(22, 33, 62, 0.4); backdrop-filter: blur(20px); border-top: 1px solid rgba(192, 192, 192, 0.1); border-bottom: 1px solid rgba(192, 192, 192, 0.1);">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">
        <MudText Typo="Typo.h3" Align="Align.Center" Class="mb-3" Style="font-weight: 700; color: rgba(255,255,255,0.95);">
            Technologies I Work With
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Class="mb-8" Style="color: rgba(255,255,255,0.5); font-weight: 400;">
            Modern tools and frameworks for building exceptional solutions
        </MudText>
        <MudGrid Justify="Justify.Center" Spacing="4">
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="0" Class="pa-4 text-center" Style="background: rgba(22, 33, 62, 0.6); backdrop-filter: blur(20px); border: 1px solid rgba(91, 141, 239, 0.3); border-radius: 16px; transition: all 0.3s; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);">
                <MudIcon Icon="@Icons.Custom.Brands.MicrosoftVisualStudio" Size="Size.Large" Style="color: #7CB8FF; font-size: 2.5rem; filter: drop-shadow(0 0 10px rgba(124, 184, 255, 0.5));" Class="mb-2" />
                <MudText Typo="Typo.body1" Style="font-weight: 600; color: rgba(255,255,255,0.9);">.NET</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="0" Class="pa-4 text-center" Style="background: rgba(22, 33, 62, 0.6); backdrop-filter: blur(20px); border: 1px solid rgba(111, 201, 215, 0.3); border-radius: 16px; transition: all 0.3s; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);">
                <MudIcon Icon="@Icons.Material.Filled.Cloud" Size="Size.Large" Style="color: #6FC9D7; font-size: 2.5rem; filter: drop-shadow(0 0 10px rgba(111, 201, 215, 0.5));" Class="mb-2" />
                <MudText Typo="Typo.body1" Style="font-weight: 600; color: rgba(255,255,255,0.9);">Azure</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="0" Class="pa-4 text-center" Style="background: rgba(22, 33, 62, 0.6); backdrop-filter: blur(20px); border: 1px solid rgba(91, 141, 239, 0.3); border-radius: 16px; transition: all 0.3s; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);">
                <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Large" Style="color: #9FD4FF; font-size: 2.5rem; filter: drop-shadow(0 0 10px rgba(159, 212, 255, 0.5));" Class="mb-2" />
                <MudText Typo="Typo.body1" Style="font-weight: 600; color: rgba(255,255,255,0.9);">C#</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="0" Class="pa-4 text-center" Style="background: rgba(22, 33, 62, 0.6); backdrop-filter: blur(20px); border: 1px solid rgba(91, 141, 239, 0.3); border-radius: 16px; transition: all 0.3s; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);">
                <MudIcon Icon="@Icons.Material.Filled.Web" Size="Size.Large" Style="color: #5B8DEF; font-size: 2.5rem; filter: drop-shadow(0 0 10px rgba(91, 141, 239, 0.5));" Class="mb-2" />
                <MudText Typo="Typo.body1" Style="font-weight: 600; color: rgba(255,255,255,0.9);">Blazor</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="0" Class="pa-4 text-center" Style="background: rgba(22, 33, 62, 0.6); backdrop-filter: blur(20px); border: 1px solid rgba(111, 201, 215, 0.3); border-radius: 16px; transition: all 0.3s; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);">
                <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Large" Style="color: #6FC9D7; font-size: 2.5rem; filter: drop-shadow(0 0 10px rgba(111, 201, 215, 0.5));" Class="mb-2" />
                <MudText Typo="Typo.body1" Style="font-weight: 600; color: rgba(255,255,255,0.9);">SQL</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="0" Class="pa-4 text-center" Style="background: rgba(22, 33, 62, 0.6); backdrop-filter: blur(20px); border: 1px solid rgba(124, 184, 255, 0.3); border-radius: 16px; transition: all 0.3s; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);">
                <MudIcon Icon="@Icons.Material.Filled.Api" Size="Size.Large" Style="color: #7CB8FF; font-size: 2.5rem; filter: drop-shadow(0 0 10px rgba(124, 184, 255, 0.5));" Class="mb-2" />
                <MudText Typo="Typo.body1" Style="font-weight: 600; color: rgba(255,255,255,0.9);">APIs</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
    </MudContainer>
</MudPaper>

<!-- Featured Projects Section -->
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-16">
    <MudText Typo="Typo.h3" Align="Align.Center" Class="mb-3" Style="font-weight: 700; color: rgba(255,255,255,0.95);">
        Featured Project
    </MudText>
    <MudText Typo="Typo.body1" Align="Align.Center" Class="mb-8" Style="color: rgba(255,255,255,0.5);">
        Computational physics meets modern web development
    </MudText>

    <MudGrid Justify="Justify.Center" Class="mb-8">
        <MudItem xs="12" md="9">
            <MudPaper Elevation="0" Class="pa-6" Style="background: rgba(22, 33, 62, 0.6); backdrop-filter: blur(20px); border: 1px solid rgba(91, 141, 239, 0.4); border-radius: 20px;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4">
                    <div Style="background: linear-gradient(135deg, #5B8DEF 0%, #6FC9D7 100%); padding: 16px; border-radius: 12px; flex-shrink: 0; display: inline-flex;">
                        <MudIcon Icon="@Icons.Material.Filled.Air" Style="color: white; font-size: 2.5rem;" />
                    </div>
                    <div Style="flex: 1;">
                        <MudText Typo="Typo.h6" Style="color: white; font-weight: 700; margin-bottom: 6px;">NACA 0012 Heat Transfer Simulation</MudText>
                        <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.65); line-height: 1.7;">
                            Real-time CFD — 134,400-node finite difference grid running live in the browser.
                        </MudText>
                    </div>
                    <MudButton Variant="Variant.Filled" Href="/projects/heat-transfer"
                               Style="background: linear-gradient(135deg, #5B8DEF 0%, #7CB8FF 100%); color: white; font-weight: 600; border-radius: 10px; text-transform: none; white-space: nowrap; flex-shrink: 0; padding: 10px 24px;">
                        Learn More
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudStack Row="true" Justify="Justify.Center">
        <MudButton Variant="Variant.Outlined" Size="Size.Medium" Href="/projects" EndIcon="@Icons.Material.Filled.ArrowForward"
                   Style="border: 2px solid rgba(91, 141, 239, 0.5); color: #E8F0FF; background: rgba(91, 141, 239, 0.1); backdrop-filter: blur(10px); padding: 12px 32px; font-weight: 600; border-radius: 10px; text-transform: none; transition: all 0.3s;">
            View All Projects
        </MudButton>
    </MudStack>
</MudContainer>