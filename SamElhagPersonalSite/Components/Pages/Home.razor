@rendermode @(new InteractiveServerRenderMode(prerender: false))


<PageTitle>Sam Elhag - Software Developer</PageTitle>

<!-- Hero Section -->
<MudContainer MaxWidth="MaxWidth.Large" Class="mt-12 mb-12">
    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" md="10" Class="text-center">
            <MudText Typo="Typo.h1" Class="mb-6" Style="font-weight: 800; font-size: 2.75rem; line-height: 1.2; color: rgba(255,255,255,0.95); text-shadow: 0 0 40px rgba(139, 0, 0, 0.3);">
                Hi, I'm Sam Elhag 🚀
            </MudText>
            <MudText Typo="Typo.h4" Class="mb-6" Style="background: linear-gradient(135deg, #ffffff  0%, #ffffff  50%, #ffffff  100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 600;">
                Developer - Analyst - Engineer
            </MudText>
            <MudText Typo="Typo.h6" Class="mb-10" Style="color: rgba(255,255,255,0.65); font-weight: 400; line-height: 1.8; max-width: 800px; margin-left: auto; margin-right: auto;">
                I bridge the gap between engineering and software — turning complex problems into clean, scalable applications. From computational simulations to production-ready tools, I build software that brings clarity to complexity.
            </MudText>
            <MudStack Row="true" Justify="Justify.Center" Spacing="4" Class="mb-4">
                <MudButton Variant="Variant.Filled" Size="Size.Large" Href="/projects" StartIcon="@Icons.Material.Filled.Work"
                          Style="background: linear-gradient(135deg, #5B8DEF 0%, #7CB8FF 100%); color: white; padding: 10px 28px; font-size: 0.95rem; font-weight: 600; border-radius: 10px; text-transform: none; box-shadow: 0 8px 32px rgba(91, 141, 239, 0.5); transition: all 0.3s;">
                    View My Work
                </MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Large" Href="/contact" StartIcon="@Icons.Material.Filled.Email"
                          Style="border: 2px solid rgba(91, 141, 239, 0.5); color: #E8F0FF; background: rgba(91, 141, 239, 0.1); backdrop-filter: blur(10px); padding: 10px 28px; font-size: 0.95rem; font-weight: 600; border-radius: 10px; text-transform: none; transition: all 0.3s;">
                    Get In Touch
                </MudButton>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudContainer>

