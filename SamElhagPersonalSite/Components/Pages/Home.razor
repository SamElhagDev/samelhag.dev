@page "/"
@using MudBlazor

<PageTitle>Sam Elhag - Software Developer</PageTitle>

<!-- Hero Section -->
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-16 mb-16">
    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" md="10" Class="text-center">
            <MudText Typo="Typo.h1" Class="mb-6" Style="font-weight: 800; font-size: 3.5rem; line-height: 1.2; color: rgba(255,255,255,0.95); text-shadow: 0 0 40px rgba(139, 0, 0, 0.3);">
                Hi, I'm Sam Elhag 🚀
            </MudText>
            <MudText Typo="Typo.h3" Class="mb-8" Style="background: linear-gradient(135deg, #7CB8FF 0%, #5B8DEF 50%, #6FC9D7 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 600;">
                Developer - Analyst - Engineer
            </MudText>
            <MudText Typo="Typo.h6" Class="mb-10" Style="color: rgba(255,255,255,0.65); font-weight: 400; line-height: 1.8; max-width: 800px; margin-left: auto; margin-right: auto;">
                I build modern web applications and cloud solutions that make a difference.
                Passionate about clean code, scalable architecture, and continuous learning.
            </MudText>
            <MudStack Row="true" Justify="Justify.Center" Spacing="4" Class="mb-4">
                <MudButton Variant="Variant.Filled" Size="Size.Large" Href="/projects" StartIcon="@Icons.Material.Filled.Work"
                          Style="background: linear-gradient(135deg, #5B8DEF 0%, #7CB8FF 100%); color: white; padding: 14px 36px; font-size: 1.05rem; font-weight: 600; border-radius: 10px; text-transform: none; box-shadow: 0 8px 32px rgba(91, 141, 239, 0.5); transition: all 0.3s;">
                    View My Work
                </MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Large" Href="/contact" StartIcon="@Icons.Material.Filled.Email"
                          Style="border: 2px solid rgba(91, 141, 239, 0.5); color: #E8F0FF; background: rgba(91, 141, 239, 0.1); backdrop-filter: blur(10px); padding: 14px 36px; font-size: 1.05rem; font-weight: 600; border-radius: 10px; text-transform: none; transition: all 0.3s;">
                    Get In Touch
                </MudButton>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudContainer>

